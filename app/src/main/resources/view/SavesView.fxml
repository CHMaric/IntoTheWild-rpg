<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane stylesheets="@../style/NestStyle.css" xmlns="http://javafx.com/javafx/21.0.2" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" spacing="40.0">
         <children>
            <Label alignment="CENTER" contentDisplay="CENTER" stylesheets="@../style/NestStyle.css" text="Salvataggi">
               <font>
                  <Font name="System Bold Italic" size="24.0" />
               </font>
            </Label>
            <ComboBox fx:id="savesComboBox" prefHeight="26.0" prefWidth="249.0" promptText="Slot salvataggi" />
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="40.0">
               <children>
                  <Button fx:id="loadButton" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" prefHeight="37.0" prefWidth="82.0" text="Carica">
                     <font>
                        <Font name="System Bold Italic" size="14.0" />
                     </font></Button>
                  <Button fx:id="delButton" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" prefHeight="39.0" prefWidth="80.0" text="Rimuovi">
                     <font>
                        <Font name="System Bold Italic" size="14.0" />
                     </font></Button>
                  <Button fx:id="goBackButton" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" prefHeight="39.0" prefWidth="82.0" text="Indietro">
                     <font>
                        <Font name="System Bold Italic" size="14.0" />
                     </font></Button>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</StackPane>
