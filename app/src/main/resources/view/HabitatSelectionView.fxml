<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.paint.RadialGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.text.Font?>

<StackPane stylesheets="@../style/HabitatSelectionStyle.css" xmlns="http://javafx.com/javafx/21.0.2" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox alignment="CENTER" prefHeight="440.0" prefWidth="376.0" spacing="70.0">
         <children>
            <Label alignment="CENTER" contentDisplay="CENTER" prefHeight="54.0" prefWidth="353.0" style="-fx-background-color: #FFFFFF;" text="Scegli il tuo Habitat" textAlignment="CENTER" underline="true">
               <font>
                  <Font name="System Bold Italic" size="36.0" />
               </font>
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
               <textFill>
                  <RadialGradient centerX="0.45132745894710574" centerY="0.5075757503509521" radius="0.5">
                     <stops>
                        <Stop>
                           <color>
                              <Color red="0.1133333370089531" green="0.6000000238418579" blue="0.21066667139530182" />
                           </color>
                        </Stop>
                        <Stop offset="1.0">
                           <color>
                              <Color />
                           </color>
                        </Stop>
                     </stops>
                  </RadialGradient>
               </textFill>
            </Label>

            <Button fx:id="alpsButton" alignment="CENTER" contentDisplay="TOP" mnemonicParsing="false" prefHeight="160.0" prefWidth="135.0" text="Alpi Italiane" textAlignment="CENTER" textFill="#1c6617">
               <font>
                  <Font name="System Bold Italic" size="16.0" />
               </font>
               <graphic>
                  <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../images/alpsBackground.jpg" />
                     </image>
                  </ImageView>
               </graphic>
            </Button>

            <Label alignment="CENTER" prefHeight="20.0" prefWidth="286.0" style="-fx-background-color: #FFFFFF;" text="Presto saranno disponibili nuovi Habitat!" textFill="#1c6617">
               <font>
                  <Font name="System Bold Italic" size="14.0" />
               </font>
            </Label>
         </children>
         <padding>
            <Insets bottom="20.0" top="20.0" />
         </padding>
      </VBox>
   </children>
</StackPane>